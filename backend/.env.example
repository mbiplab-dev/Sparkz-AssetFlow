DEBUG=True
# HS256 JWT needs ≥32 bytes — override in production.
SECRET_KEY=django-insecure-assetflow-dev-key-change-me-32b+

POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

REFRESH_COOKIE_SAMESITE=Lax
REFRESH_COOKIE_SECURE=False

# Frontend origins allowed to call the API with cookies.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001

# Comma-separated hosts Django will serve (add tunnel hostnames if needed).
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,testserver

# Console backend prints OTP codes in the Django terminal (best for local dev).
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST_USER=
GOOGLE_SMTP_PASSWORD=

# Auto-seeded admin (created on first migrate via organization.0002_seed_admin)
ADMIN_EMAIL=admin@assetflow.local
ADMIN_PASSWORD=Admin@12345
ADMIN_NAME=Administrator
